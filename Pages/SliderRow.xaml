<UserControl x:Class="LiveWallpaper.Pages.SliderRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="110"/>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="46"/>
    </Grid.ColumnDefinitions>

    <TextBlock x:Name="LabelText" Grid.Column="0"
               Foreground="#505878" FontSize="12"
               VerticalAlignment="Center"/>

    <!-- Slider with center marker -->
    <Grid Grid.Column="1" Margin="0,0,10,0">
      <Slider x:Name="TheSlider"
              VerticalAlignment="Center"
              TickFrequency="100"
              TickPlacement="None"
              ValueChanged="Slider_ValueChanged"/>
      <!-- Center tick mark at 0 -->
      <Rectangle Width="1" Height="7"
                 Fill="#2D3350"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 Margin="0,0,0,-1"
                 IsHitTestVisible="False"/>
    </Grid>

    <Border Grid.Column="2"
            Background="#09090F"
            BorderBrush="#191D2F" BorderThickness="1"
            CornerRadius="5" Padding="2,0">
      <TextBlock x:Name="ValueText"
                 FontSize="11" FontFamily="Consolas"
                 Foreground="#6070AA"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
    </Border>
  </Grid>
</UserControl>
