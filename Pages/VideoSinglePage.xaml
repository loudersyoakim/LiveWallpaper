<Page x:Class="LiveWallpaper.Pages.VideoSinglePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LiveWallpaper.Pages"
      Background="{StaticResource BrBg0}"
      Title="Single File">

  <ScrollViewer>
    <StackPanel Margin="28,24,28,28" MaxWidth="620">

      <!-- Header -->
      <TextBlock Text="Single File Wallpaper"
                 FontSize="16" FontWeight="SemiBold" Margin="0,0,0,2"/>
      <TextBlock Text="Loops one video file as your desktop wallpaper."
                 FontSize="12" Foreground="{StaticResource BrTextDim}" Margin="0,0,0,22"/>

      <!-- FILE -->
      <Border Background="#11141F" BorderBrush="{StaticResource BrBorder}"
              BorderThickness="1" CornerRadius="10" Padding="16,13" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="Video File" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,9"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Background="#09090F" BorderBrush="{StaticResource BrBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,8,0">
              <TextBlock x:Name="FileLbl" Text="No file selected"
                         FontSize="12" FontFamily="Consolas"
                         Foreground="{StaticResource BrTextDim}"
                         TextTrimming="CharacterEllipsis"/>
            </Border>
            <Button Grid.Column="1" Style="{StaticResource BrowseBtn}"
                    Content="Browse" Click="OnBrowse"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- SETTINGS -->
      <Border Background="#11141F" BorderBrush="{StaticResource BrBorder}"
              BorderThickness="1" CornerRadius="10" Padding="16,13" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,14"/>

          <!-- Monitor -->
          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Monitor" FontSize="12"
                       Foreground="{StaticResource BrTextMuted}"
                       VerticalAlignment="Center"/>
            <ComboBox x:Name="CboMonitor" Grid.Column="1"
                      SelectionChanged="OnSettingChanged"/>
          </Grid>

          <!-- Scale mode -->
          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Scale Mode" FontSize="12"
                       Foreground="{StaticResource BrTextMuted}"
                       VerticalAlignment="Center"/>
            <ComboBox x:Name="CboFit" Grid.Column="1"
                      SelectionChanged="OnSettingChanged"/>
          </Grid>

          <local:SliderRow x:Name="SldVolume"   Label="Volume"
                           Minimum="0" Maximum="100"
                           Margin="0,0,0,7" ValueChanged="OnSettingChanged"/>
          <local:SliderRow x:Name="SldSpeed"    Label="Speed"
                           Minimum="-100" Maximum="100"
                           Margin="0,0,0,7" ValueChanged="OnSettingChanged"/>
          <local:SliderRow x:Name="SldBright"   Label="Brightness"
                           Minimum="-100" Maximum="100"
                           Margin="0,0,0,7" ValueChanged="OnSettingChanged"/>
          <local:SliderRow x:Name="SldContrast" Label="Contrast"
                           Minimum="-100" Maximum="100"
                           Margin="0,0,0,7" ValueChanged="OnSettingChanged"/>
          <local:SliderRow x:Name="SldPanX"     Label="Pan X"
                           Minimum="-100" Maximum="100"
                           Margin="0,0,0,7" ValueChanged="OnSettingChanged"/>
          <local:SliderRow x:Name="SldPanY"     Label="Pan Y"
                           Minimum="-100" Maximum="100"
                           ValueChanged="OnSettingChanged"/>
        </StackPanel>
      </Border>

      <!-- ACTIONS -->
      <StackPanel Orientation="Horizontal">
        <Button Style="{StaticResource GhostBtn}" Content="Stop"
                Click="OnStop" Width="80"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</Page>
