<Page x:Class="LiveWallpaper.Pages.VideoBatchPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:LiveWallpaper.Pages"
      Background="{StaticResource BrBg0}"
      Title="Folder Playlist">

  <ScrollViewer>
    <StackPanel Margin="28,24,28,28" MaxWidth="620">

      <!-- Header -->
      <TextBlock Text="Folder Playlist"
                 FontSize="16" FontWeight="SemiBold" Margin="0,0,0,2"/>
      <TextBlock Text="Play all videos in a folder, one at a time."
                 FontSize="12" Foreground="{StaticResource BrTextDim}" Margin="0,0,0,22"/>

      <!-- FOLDER -->
      <Border Background="#11141F" BorderBrush="{StaticResource BrBorder}"
              BorderThickness="1" CornerRadius="10" Padding="16,13" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="Folder" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,9"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Background="#09090F" BorderBrush="{StaticResource BrBorder}"
                    BorderThickness="1" CornerRadius="6" Padding="10,6" Margin="0,0,8,0">
              <TextBlock x:Name="FolderLbl" Text="No folder selected"
                         FontSize="11" FontFamily="Consolas"
                         Foreground="{StaticResource BrTextDim}"
                         TextTrimming="CharacterEllipsis"/>
            </Border>
            <Button Grid.Column="1" Style="{StaticResource BrowseBtn}"
                    Content="Browse" Click="OnBrowse"/>
          </Grid>
          <TextBlock x:Name="CountLbl" Text="0 video file(s) found"
                     FontSize="11" Foreground="{StaticResource BrTextDim}"
                     Margin="0,7,0,0"/>
        </StackPanel>
      </Border>

      <!-- FILE LIST -->
      <Border Background="#11141F" BorderBrush="{StaticResource BrBorder}"
              BorderThickness="1" CornerRadius="10" Padding="16,13" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="Files" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,9"/>
          <Border Background="#09090F" BorderBrush="{StaticResource BrBorder}"
                  BorderThickness="1" CornerRadius="6">
            <ListBox x:Name="FileList"
                     Height="130"
                     Background="Transparent"
                     BorderThickness="0"
                     FontSize="11" FontFamily="Consolas"
                     Foreground="{StaticResource BrTextMuted}"/>
          </Border>
        </StackPanel>
      </Border>

      <!-- SETTINGS -->
      <Border Background="#11141F" BorderBrush="{StaticResource BrBorder}"
              BorderThickness="1" CornerRadius="10" Padding="16,13" Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Text="Settings" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,14"/>

          <!-- Monitor -->
          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Monitor" FontSize="12"
                       Foreground="{StaticResource BrTextMuted}"
                       VerticalAlignment="Center"/>
            <ComboBox x:Name="CboMonitor" Grid.Column="1"
                      SelectionChanged="OnSettingChanged"/>
          </Grid>

          <!-- Scale mode -->
          <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Scale Mode" FontSize="12"
                       Foreground="{StaticResource BrTextMuted}"
                       VerticalAlignment="Center"/>
            <ComboBox x:Name="CboFit" Grid.Column="1"
                      SelectionChanged="OnSettingChanged"/>
          </Grid>

          <!-- Auto-switch interval -->
          <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Switch Interval" FontSize="12"
                       Foreground="{StaticResource BrTextMuted}"
                       VerticalAlignment="Center"/>
            <ComboBox x:Name="CboInterval" Grid.Column="1"
                      SelectionChanged="OnIntervalChanged"/>
          </Grid>

          <local:SliderRow x:Name="SldVolume"   Label="Volume"
                           Minimum="0" Maximum="100"
                           Margin="0,0,0,7" ValueChanged="OnSettingChanged"/>
          <local:SliderRow x:Name="SldSpeed"    Label="Speed"
                           Minimum="-100" Maximum="100"
                           Margin="0,0,0,7" ValueChanged="OnSettingChanged"/>
          <local:SliderRow x:Name="SldBright"   Label="Brightness"
                           Minimum="-100" Maximum="100"
                           Margin="0,0,0,7" ValueChanged="OnSettingChanged"/>
          <local:SliderRow x:Name="SldContrast" Label="Contrast"
                           Minimum="-100" Maximum="100"
                           Margin="0,0,0,7" ValueChanged="OnSettingChanged"/>
          <local:SliderRow x:Name="SldPanX"     Label="Pan X"
                           Minimum="-100" Maximum="100"
                           Margin="0,0,0,7" ValueChanged="OnSettingChanged"/>
          <local:SliderRow x:Name="SldPanY"     Label="Pan Y"
                           Minimum="-100" Maximum="100"
                           ValueChanged="OnSettingChanged"/>

          <!-- Shuffle -->
          <CheckBox x:Name="ChkShuffle" Content="Shuffle playlist"
                    FontSize="12" Foreground="{StaticResource BrTextMuted}"
                    Margin="0,12,0,0"
                    Checked="OnOptionChanged" Unchecked="OnOptionChanged"/>
        </StackPanel>
      </Border>

      <!-- SCHEDULER STATUS -->
      <TextBlock x:Name="SchedLbl"
                 FontSize="11" Foreground="{StaticResource BrTextDim}"
                 Margin="0,0,0,12"/>

      <!-- ACTIONS -->
      <StackPanel Orientation="Horizontal">
        <Button x:Name="BtnStart"
                Style="{StaticResource PrimaryBtn}"
                Content="Start Playlist"
                IsEnabled="False"
                Width="130" Margin="0,0,8,0"
                Click="OnStart"/>
        <Button Style="{StaticResource GhostBtn}" Content="Prev"
                Width="60" Margin="0,0,8,0"
                Click="OnPrev"/>
        <Button Style="{StaticResource GhostBtn}" Content="Next"
                Width="60" Margin="0,0,8,0"
                Click="OnNext"/>
        <Button Style="{StaticResource GhostBtn}" Content="Stop"
                Width="60"
                Click="OnStop"/>
      </StackPanel>

    </StackPanel>
  </ScrollViewer>
</Page>
